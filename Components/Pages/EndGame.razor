@page "/endgame"
@inject NavigationManager NavManager
@inject GameState GameState

<div class="screen-center fade-in">
    <div class="glass-card">
        <h1>Partita Terminata</h1>
        <p>Ecco le statistiche finali della squadra.</p>

        <div class="stats-container mt-4 mb-4">
            <div class="stat-box">
                <div class="stat-label">Squadra</div>
                <div class="stat-value text-xl">@GameState.TeamName</div>
            </div>
            
            <div class="stat-box mt-3">
                <div class="stat-label">Modalità</div>
                <div class="stat-value text-lg">@GetModeName()</div>
            </div>
            
            @if (GameState.ModeInt > 0)
            {
                <div class="stat-box mt-3">
                    <div class="stat-label">@(GameState.Mode == "deathmatch" ? "Morti Subite" : "Bandiere Catturate")</div>
                    <div class="stat-value text-3xl text-primary">@GameState.Score</div>
                </div>
            }
        </div>

        <button class="btn-modern btn-primary mt-4" @onclick="Continua">
            <span>Nuova Partita</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon">
                <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.59-9.21l5.67-5.67"></path>
            </svg>
        </button>
    </div>
</div>

<style>
    .stats-container {
        background: rgba(0, 0, 0, 0.2);
        border-radius: 16px;
        padding: 1.5rem;
    }

    .stat-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 10px;
    }
    
    .stat-box:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .stat-label {
        font-size: 0.9rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .stat-value {
        font-weight: 800;
        color: white;
    }

    .text-primary {
        color: var(--primary-color);
        text-shadow: 0 0 10px rgba(59, 130, 246, 0.4);
    }
    
    .text-3xl {
        font-size: 3rem;
    }
    
    .text-xl {
        font-size: 1.5rem;
    }
    
    .text-lg {
        font-size: 1.25rem;
    }
</style>

@code {
    private void Continua()
    {
        NavManager.NavigateTo("/gamemode", replace: true);
    }

    private string GetModeName()
    {
        return GameState.Mode switch
        {
            "deathmatch" => "Deathmatch",
            "catturabandiera" => "Cattura Bandiera",
            "bomb" => "Bomb",
            "dominio" => "Dominio",
            _ => GameState.Mode
        };
    }
}
