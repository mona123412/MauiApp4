@page "/"
@inject NavigationManager NavManager

<div class="screen-center fade-in">
    <div class="glass-card">
        <div class="icon-pulse wifi-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12.55a11 11 0 0 1 14.08 0"></path>
                <path d="M1.42 9a16 16 0 0 1 21.16 0"></path>
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
                <line x1="12" y1="20" x2="12.01" y2="20"></line>
            </svg>
        </div>
        <h1>Connessione Wi-Fi</h1>
        <p>In attesa di accesso alla rete Wi-Fi...</p>
        <div class="progress-bar-container">
            <div class="progress-bar"></div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // aspetta 10 secondi per simulare la connessione wi-fi
        await Task.Delay(10000);
        NavManager.NavigateTo("/gamemode", replace: true);
    }
}
