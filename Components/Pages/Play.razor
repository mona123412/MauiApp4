@page "/play"
@inject NavigationManager NavManager
@inject GameState GameState
@inject INfcService NfcService
@inject IJSRuntime JS
@implements IDisposable

<div class="page-wrapper">
    <div class="play-card fade-in">

        <div class="header-section">
            <h2 class="team-name">@GameState.TeamName</h2>
            <div class="timer-display @(GameState.RemainingTimeSeconds <= 10 ? "danger-time" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="timer-icon">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                @TimeSpan.FromSeconds(GameState.RemainingTimeSeconds).ToString(@"mm\:ss")
            </div>
        </div>

        <div class="content-section">
            @if (GameState.Mode == "deathmatch")
            {
                <div class="mode-info">
                    <span class="mode-badge badge-deathmatch">Deathmatch</span>
                    <p class="mode-desc">Clicca quando vieni colpito</p>
                </div>

                <div class="score-display">
                    <div class="score-label">Morti</div>
                    <div class="score-value">@GameState.Score</div>
                </div>

                <div class="action-container" style="--accent-glow: rgba(225, 29, 72, 0.5);">
                    <button class="big-action-btn deathmatch-btn @(isDeathClicked ? "clicked-animation" : "")" @onclick="RecordDeath">
                        <div class="btn-content">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2v20"></path>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                            <span>Sono Morto</span>
                        </div>
                    </button>
                </div>
            }
            else if (GameState.Mode == "catturabandiera")
            {
                <div class="mode-info">
                    <span class="mode-badge badge-ctf">Cattura Bandiera</span>
                    <p class="mode-desc">Avvicina il tag NFC alla bandiera</p>
                </div>

                <div class="score-display score-display--big">
                    <div class="score-label">Bandiere Catturate</div>
                    <div class="score-value score-value--huge">@GameState.Score</div>
                    <div class="score-sublabel">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1rem;height:1rem;display:inline;margin-right:0.3rem;">
                            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
                            <line x1="4" y1="22" x2="4" y2="15"></line>
                        </svg>
                        in attesa di tag NFC...
                    </div>
                </div>
            }
            else if (GameState.Mode == "bomb")
            {
                <div class="mode-info">
                    <span class="mode-badge badge-bomb">Bomb</span>
                    <p class="mode-desc">Gestito dal dispositivo centrale</p>
                </div>
            }
            else if (GameState.Mode == "dominio")
            {
                <div class="mode-info">
                    <span class="mode-badge badge-dominio">Dominio</span>
                    <p class="mode-desc">Gestito dal dispositivo centrale</p>
                </div>
            }
        </div>

        <div class="footer-section">
            <button class="btn-stop" @onclick="ConfirmStopGame">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                </svg>
                Termina Partita
            </button>
        </div>

    </div>
</div>

<style>
    .page-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: 100vh;
        min-height: 100dvh;
        width: 100%;
        padding: 1rem;
        box-sizing: border-box;
        overflow-y: auto;
    }

    .play-card {
        max-width: 520px;
        width: 100%;
        padding: 1.5rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(20, 20, 30, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
        box-sizing: border-box;
        /* Su schermi alti si centra verticalmente */
        margin: auto;
    }

    /* ── Header ── */
    .header-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 1.5rem;
        width: 100%;
    }

    .team-name {
        font-size: 1rem;
        font-weight: 600;
        color: #a0aec0;
        margin: 0 0 0.4rem 0;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .timer-display {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        font-size: clamp(2.5rem, 10vw, 3.5rem);
        font-weight: 800;
        color: #ffffff;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    .timer-icon {
        width: clamp(1.8rem, 6vw, 2.5rem);
        height: clamp(1.8rem, 6vw, 2.5rem);
        color: #4facfe;
        opacity: 0.8;
    }

    .danger-time {
        color: #ef4444;
        animation: pulse-danger 1s infinite;
    }
    .danger-time .timer-icon { color: #ef4444; }

    @@keyframes pulse-danger {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.05); }
    }

    /* ── Content ── */
    .content-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        flex: 1;
    }

    .mode-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .mode-badge {
        padding: 0.35rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.4rem;
    }

    .badge-deathmatch { background: rgba(239,68,68,0.2); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }
    .badge-ctf        { background: rgba(59,130,246,0.2); color: #93c5fd; border: 1px solid rgba(59,130,246,0.3); }
    .badge-bomb       { background: rgba(234,179,8,0.2);  color: #fde047; border: 1px solid rgba(234,179,8,0.3); }
    .badge-dominio    { background: rgba(168,85,247,0.2); color: #d8b4fe; border: 1px solid rgba(168,85,247,0.3); }

    .mode-desc {
        color: #9ca3af;
        font-size: 0.85rem;
        margin: 0;
        text-align: center;
    }

    /* ── Score ── */
    .score-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(255,255,255,0.03);
        border-radius: 20px;
        padding: 1rem 2rem;
        margin-bottom: 2rem;
        border: 1px solid rgba(255,255,255,0.06);
        min-width: 150px;
    }

    /* Versione grande per catturabandiera (niente bottone) */
    .score-display--big {
        padding: clamp(1.5rem, 5vw, 2.5rem) clamp(2rem, 8vw, 4rem);
        margin-bottom: 0;
        border-radius: 28px;
        background: rgba(59, 130, 246, 0.06);
        border: 1px solid rgba(59, 130, 246, 0.15);
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.08);
        width: 100%;
        box-sizing: border-box;
    }

    .score-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #9ca3af;
        letter-spacing: 1px;
        margin-bottom: 0.2rem;
    }

    .score-value {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff, #a0aec0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }

    .score-value--huge {
        font-size: clamp(5rem, 22vw, 8rem);
        background: linear-gradient(135deg, #93c5fd, #ffffff, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: none;
        margin: 0.3rem 0;
        line-height: 1;
    }

    .score-sublabel {
        font-size: 0.8rem;
        color: #6b7280;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.2rem;
    }

    /* ── Deathmatch button ── */
    .action-container {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 1rem;
        position: relative;
    }

    .action-container::before {
        content: '';
        position: absolute;
        width: 170px;
        height: 170px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
        z-index: 0;
        opacity: 0.5;
        filter: blur(20px);
    }

    .big-action-btn {
        position: relative;
        width: clamp(130px, 40vw, 160px);
        height: clamp(130px, 40vw, 160px);
        border-radius: 50%;
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        -webkit-tap-highlight-color: transparent;
    }

    .deathmatch-btn {
        background: linear-gradient(135deg, #e11d48, #9f1239);
        box-shadow: 0 10px 25px rgba(225,29,72,0.4), inset 0 2px 0 rgba(255,255,255,0.2);
    }
    .deathmatch-btn:hover { transform: translateY(-4px) scale(1.02); }
    .deathmatch-btn:active, .clicked-animation {
        transform: translateY(2px) scale(0.95) !important;
        box-shadow: 0 0 40px rgba(244,63,94,0.8), inset 0 2px 0 rgba(255,255,255,0.4) !important;
        transition: all 0.1s ease !important;
    }

    .btn-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        pointer-events: none;
    }
    .btn-content svg { width: 2.5rem; height: 2.5rem; }
    .btn-content span { font-weight: 700; font-size: 1rem; letter-spacing: 0.5px; }

    /* ── Footer / Stop button ── */
    .footer-section {
        width: 100%;
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .btn-stop {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        background: linear-gradient(135deg, #ef4444, #b91c1c);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.85rem 1rem;
        border-radius: 30px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 8px 15px rgba(185,28,28,0.3);
        box-sizing: border-box;
    }
    .btn-stop svg { width: 1.1rem; height: 1.1rem; flex-shrink: 0; }
    .btn-stop:hover { transform: translateY(-2px); box-shadow: 0 12px 20px rgba(185,28,28,0.4); }
    .btn-stop:active { transform: translateY(1px); }
</style>

@code {
    private bool isDeathClicked = false;
    private Action _onChangeHandler;

    protected override void OnInitialized()
    {
        _onChangeHandler = () => InvokeAsync(StateHasChanged);
        GameState.OnChange += _onChangeHandler;
        GameState.OnTimeUp += HandleTimeUp;

        if (!GameState.IsGameRunning && GameState.RemainingTimeSeconds == 0)
            GameState.StartGame(GameState.TotalTimeMinutes);
        else
            GameState.ResumeTimer();

        if (GameState.Mode == "catturabandiera")
        {
            NfcService.TagDetected += OnNfcTagDetected;
            NfcService.StartListening();
        }
    }

    private void OnNfcTagDetected(object? sender, MauiApp4.Services.NfcTagEventArgs e)
    {
        InvokeAsync(async () =>
        {
            var uid = e.Uid ?? "UID sconosciuto";
            await MainThread.InvokeOnMainThreadAsync(() =>
                Application.Current!.MainPage!.DisplayAlert("Tag NFC", $"UID: {uid}", "OK")
            );

            if (uid?.Equals("9C650CA8", StringComparison.OrdinalIgnoreCase) == true)
            {
                GameState.AddScore();
                NavManager.NavigateTo("/pregame", replace: true);
            }
        });
    }

    private async Task RecordDeath()
    {
        GameState.AddScore();
        isDeathClicked = true;
        StateHasChanged();
        await Task.Delay(300);
        isDeathClicked = false;
        StateHasChanged();
    }

    private async Task ConfirmStopGame()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Sei sicuro di voler terminare la partita in anticipo?");
        if (confirmed)
        {
            GameState.StopGame();
            NavManager.NavigateTo("/endgame", replace: true);
        }
    }

    private void HandleTimeUp()
    {
        InvokeAsync(() =>
        {
            GameState.StopGame();
            NavManager.NavigateTo("/endgame", replace: true);
        });
    }

    public void Dispose()
    {
        GameState.OnChange -= _onChangeHandler;
        GameState.OnTimeUp -= HandleTimeUp;
        NfcService.TagDetected -= OnNfcTagDetected;
        NfcService.StopListening();
    }
}