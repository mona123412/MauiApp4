@page "/play"
@inject NavigationManager NavManager
@inject GameState GameState
@inject INfcService NfcService
@inject IJSRuntime JS
@implements IDisposable

<div class="screen-center fade-in">
    <div class="glass-card game-card play-card">
        
        <div class="header-section">
            <h2 class="team-name">@GameState.TeamName</h2>
            <div class="timer-display @(GameState.RemainingTimeSeconds <= 10 ? "danger-time" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="timer-icon">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                @TimeSpan.FromSeconds(GameState.RemainingTimeSeconds).ToString(@"mm\:ss")
            </div>
        </div>

        @if (GameState.Mode == "deathmatch")
        {
            <div class="mode-info">
                <span class="mode-badge badge-deathmatch">Deathmatch</span>
                <p class="mode-desc">Clicca quando vieni colpito</p>
            </div>
            
            <div class="score-display">
                <div class="score-label">Morti</div>
                <div class="score-value">@GameState.Score</div>
            </div>

            <div class="action-container" style="--accent-glow: rgba(225, 29, 72, 0.5);">
                <button class="big-action-btn deathmatch-btn @(isDeathClicked ? "clicked-animation" : "")" @onclick="RecordDeath">
                    <div class="btn-content">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 2v20"></path>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <span>Sono Morto</span>
                    </div>
                </button>
            </div>
        }
        else if (GameState.Mode == "catturabandiera")
        {
            <div class="mode-info">
                <span class="mode-badge badge-ctf">Cattura Bandiera</span>
                <p class="mode-desc">Tieni premuto per 5 secondi</p>
            </div>
            
            <div class="score-display">
                <div class="score-label">Bandiere</div>
                <div class="score-value">@GameState.Score</div>
            </div>

            <div class="action-container" style="--accent-glow: rgba(245, 158, 11, 0.5);">
                <button class="big-action-btn @(isHolding ? "holding pulse-animation" : "not-ready")"
                        @onmousedown="StartHold" @onmouseup="StopHold" @onmouseleave="StopHold"
                        @ontouchstart="StartHold" @ontouchend="StopHold" @ontouchcancel="StopHold">
                    <div class="btn-content">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
                            <line x1="4" y1="22" x2="4" y2="15"></line>
                        </svg>
                        <span>@(isHolding ? "Rilevamento..." : "Scansiona NFT")</span>
                    </div>
                </button>
            </div>
        }
        else if (GameState.Mode == "bomb")
        {
            <div class="mode-info">
                <span class="mode-badge" style="background: rgba(234, 179, 8, 0.2); color: #fde047; border: 1px solid rgba(234, 179, 8, 0.3);">Bomb</span>
                <p class="mode-desc">Gestito dal dispositivo centrale</p>
            </div>
        }
        else if (GameState.Mode == "dominio")
        {
            <div class="mode-info">
                <span class="mode-badge" style="background: rgba(168, 85, 247, 0.2); color: #d8b4fe; border: 1px solid rgba(168, 85, 247, 0.3);">Dominio</span>
                <p class="mode-desc">Gestito dal dispositivo centrale</p>
            </div>
        }

        <button class="btn-modern btn-danger mt-4" @onclick="ConfirmStopGame">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 1.2rem; height: 1.2rem; margin-right: 0.5rem;">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="9" y1="9" x2="15" y2="15"></line>
                <line x1="15" y1="9" x2="9" y2="15"></line>
            </svg>
            Termina Partita
        </button>
    </div>
</div>

<style>
    :root {
        --primary-color: #7928ca;
        --primary-dark: #ff0080;
        --accent-glow: rgba(255, 0, 128, 0.5);
    }

    .screen-center {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        min-height: 100dvh;
        width: 100%;
        padding: 1rem;
    }

    .play-card {
        max-width: 600px;
        width: 90%;
        padding: 2.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(20, 20, 30, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
    }

    .header-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 2rem;
        width: 100%;
    }

    .team-name {
        font-size: 1.2rem;
        font-weight: 600;
        color: #a0aec0;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .timer-display {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 3.5rem;
        font-weight: 800;
        color: #ffffff;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    .timer-icon {
        width: 2.5rem;
        height: 2.5rem;
        color: #4facfe;
        opacity: 0.8;
    }

    .danger-time {
        color: #ef4444;
        animation: pulse-danger 1s infinite;
    }

    .danger-time .timer-icon {
        color: #ef4444;
    }

    @@keyframes pulse-danger {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.05); }
    }

    .mode-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .mode-badge {
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    .badge-deathmatch {
        background: rgba(239, 68, 68, 0.2);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .badge-ctf {
        background: rgba(59, 130, 246, 0.2);
        color: #93c5fd;
        border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .mode-desc {
        color: #9ca3af;
        font-size: 0.9rem;
        margin: 0;
    }

    .score-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 1rem 2rem;
        margin-bottom: 2.5rem;
        border: 1px solid rgba(255,255,255,0.05);
        min-width: 150px;
    }

    .score-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #9ca3af;
        letter-spacing: 1px;
        margin-bottom: 0.2rem;
    }

    .score-value {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff, #a0aec0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }

    .action-container {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 1.5rem;
        position: relative;
    }

    .action-container::before {
        content: '';
        position: absolute;
        width: 170px;
        height: 170px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
        z-index: 0;
        opacity: 0.5;
        filter: blur(20px);
    }

    .big-action-btn {
        position: relative;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        z-index: 1;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        -webkit-tap-highlight-color: transparent;
    }

    .deathmatch-btn {
        background: linear-gradient(135deg, #e11d48, #9f1239);
        box-shadow: 0 10px 25px rgba(225, 29, 72, 0.4), inset 0 2px 0 rgba(255,255,255,0.2);
    }

    .deathmatch-btn:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 15px 35px rgba(225, 29, 72, 0.6), inset 0 2px 0 rgba(255,255,255,0.2);
    }

    .deathmatch-btn:active, .clicked-animation {
        transform: translateY(2px) scale(0.95) !important;
        background: linear-gradient(135deg, #f43f5e, #be123c) !important;
        box-shadow: 0 0 40px rgba(244, 63, 94, 0.8), inset 0 2px 0 rgba(255,255,255,0.4) !important;
        transition: all 0.1s ease !important;
    }

    .big-action-btn.not-ready {
        background: linear-gradient(135deg, #374151, #1f2937);
        box-shadow: 0 10px 25px rgba(0,0,0,0.4), inset 0 2px 0 rgba(255,255,255,0.1);
        color: #9ca3af;
    }

    .big-action-btn.holding {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        box-shadow: 0 0 30px rgba(245, 158, 11, 0.6), inset 0 2px 0 rgba(255,255,255,0.3);
        transform: scale(0.95);
    }

    .btn-content {
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        pointer-events: none;
    }

    .btn-content svg {
        width: 3rem;
        height: 3rem;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    }

    .btn-content span {
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .progress-ring {
        position: absolute;
        top: 0;
        left: 0;
        width: 160px;
        height: 160px;
        z-index: 2;
        pointer-events: none;
        transform: rotate(-90deg);
        transform-origin: center;
    }

    .progress-ring circle {
        transition: stroke-dashoffset 0.1s linear;
    }

    .pulse-animation {
        animation: pulse-glow 2s infinite;
    }

    @@keyframes pulse-glow {
        0% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
        70% { box-shadow: 0 0 0 20px rgba(245, 158, 11, 0); }
        100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    }

    .btn-danger {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ef4444, #b91c1c);
        color: white;
        margin-top: 1rem;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.8rem 2rem;
        border-radius: 30px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 8px 15px rgba(185, 28, 28, 0.3);
    }

    .btn-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(185, 28, 28, 0.4);
    }

    .btn-danger:active {
        transform: translateY(1px);
    }
</style>

@code {
    private bool isHolding = false;
    private double holdingProgress = 0;
    private bool isDeathClicked = false;
    private System.Timers.Timer _holdTimer;
    private System.Timers.Timer _progressTimer;
    private DateTime _holdStartTime;

    private const double FullCircle = 452.4;
    private Action _onChangeHandler;

    protected override void OnInitialized()
    {
        _onChangeHandler = () => InvokeAsync(StateHasChanged);
        GameState.OnChange += _onChangeHandler;
        GameState.OnTimeUp += HandleTimeUp;

        if (!GameState.IsGameRunning && GameState.RemainingTimeSeconds == 0)
            GameState.StartGame(GameState.TotalTimeMinutes);
        else
            GameState.ResumeTimer();

        // ── NFC: attiva solo in modalità catturabandiera ──
        if (GameState.Mode == "catturabandiera")
        {
            NfcService.TagDetected += OnNfcTagDetected;
            NfcService.StartListening();
        }

        // Timer hold (usato come fallback / animazione visiva)
        _holdTimer = new System.Timers.Timer(5000);
        _holdTimer.AutoReset = false;
        _holdTimer.Elapsed += (s, e) =>
        {
            InvokeAsync(() =>
            {
                isHolding = false;
                holdingProgress = 0;
                GameState.AddScore();
                NavManager.NavigateTo("/pregame", replace: true);
            });
        };

        _progressTimer = new System.Timers.Timer(50);
        _progressTimer.Elapsed += (s, e) =>
        {
            InvokeAsync(() =>
            {
                if (isHolding)
                {
                    var elapsed = (DateTime.UtcNow - _holdStartTime).TotalMilliseconds;
                    holdingProgress = Math.Min(elapsed / 5000.0, 1.0);
                    StateHasChanged();
                }
            });
        };
    }

    // ── Callback NFC ──────────────────────────────────────
    private void OnNfcTagDetected(object? sender, MauiApp4.Services.NfcTagEventArgs e)
    {
        InvokeAsync(async () =>
        {
            var uid = e.Uid ?? "UID sconosciuto";
            await MainThread.InvokeOnMainThreadAsync(() =>
                Application.Current!.MainPage!.DisplayAlert("Tag NFC", $"UID: {uid}", "OK")
            );

            if(uid?.Equals("9C650CA8", StringComparison.OrdinalIgnoreCase) == true){
                isHolding = false;
                holdingProgress = 0;
                GameState.AddScore();
                NavManager.NavigateTo("/pregame", replace: true);
            }
        });
    }

    private double GetDashOffset() => FullCircle * (1 - holdingProgress);

    private async Task RecordDeath()
    {
        GameState.AddScore();
        isDeathClicked = true;
        StateHasChanged();
        await Task.Delay(300);
        isDeathClicked = false;
        StateHasChanged();
    }

    private void StartHold()
    {
        isHolding = true;
        holdingProgress = 0;
        _holdStartTime = DateTime.UtcNow;
        _holdTimer.Start();
        _progressTimer.Start();
    }

    private void StopHold()
    {
        if (isHolding)
        {
            isHolding = false;
            holdingProgress = 0;
            _holdTimer.Stop();
            _progressTimer.Stop();
            StateHasChanged();
        }
    }

    private async Task ConfirmStopGame()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Sei sicuro di voler terminare la partita in anticipo?");
        if (confirmed)
        {
            GameState.StopGame();
            NavManager.NavigateTo("/endgame", replace: true);
        }
    }

    private void HandleTimeUp()
    {
        InvokeAsync(() =>
        {
            GameState.StopGame();
            NavManager.NavigateTo("/endgame", replace: true);
        });
    }

    public void Dispose()
    {
        GameState.OnChange -= _onChangeHandler;
        GameState.OnTimeUp -= HandleTimeUp;

        // ── Deregistra NFC ──
        NfcService.TagDetected -= OnNfcTagDetected;
        NfcService.StopListening();

        _holdTimer?.Dispose();
        _progressTimer?.Dispose();
    }
}